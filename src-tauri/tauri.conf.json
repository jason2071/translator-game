{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RPGMaker Translator",
  "version": "0.12.6",
  "identifier": "com.rpgtl.translator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RPGMaker Translator",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxRTIwRDY5NjRERTkyRjIKUldUeWt0NWthUTNpd2RtU01Eem9LVkdQWXJWUGlPOWdaclhxVGY4TVlhWFFwQ0FQMlRwQ3VLd1AK",
      "endpoints": [
        "https://github.com/jason2071/translator-game/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
