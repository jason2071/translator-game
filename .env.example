# Local development API keys.
#
# Copy this file to `.env` (which is git-ignored) and fill in the keys for the
# providers you use. `pnpm tauri dev` loads `.env` automatically and the Rust
# side reads these via keys::get_key's env fallback — no OS keychain entry
# needed. This is DEBUG-ONLY: release builds ignore `.env` and read the keychain.
#
# An env var takes precedence over a key stored in the keychain. Each provider
# accepts either the RPGTL_KEY_<KIND> name or its conventional name (shown).
# `local` (Ollama / self-hosted) usually needs no key.

# OpenAI
RPGTL_KEY_OPENAI=
# OPENAI_API_KEY=

# OpenRouter
RPGTL_KEY_OPENROUTER=
# OPENROUTER_API_KEY=

# Anthropic
RPGTL_KEY_ANTHROPIC=
# ANTHROPIC_API_KEY=

# Google Gemini
RPGTL_KEY_GEMINI=
# GEMINI_API_KEY=
