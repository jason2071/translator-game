# Node
node_modules/
dist/
dist-ssr/
*.local

# Editors / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
desktop.ini
ui/

# Obsidian vault config (docs/ is also an Obsidian vault) — per-user UI state,
# workspace layout, and cache; not shared. The Markdown notes are still tracked.
.obsidian/

# graphify knowledge-graph output (generated locally — HTML/JSON viz, cache,
# manifest, cost tracker). Regenerate with `/graphify .`; not shared state.
graphify-out/

# Rust / Tauri
src-tauri/target/
src-tauri/gen/

# Secrets / env — never commit API keys
.env
.env.*
!.env.example
*.pem
*.key

# App project data (sidecar created next to a game, and any local test games)
.rpgtl/
/games/
/test-games/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
